DATABASE_URL="postgresql://postgres:postgres@localhost:5432/metamystic?schema=public"

# Chat provider for AI consultation. Valid values: openai, deepseek.
# DeepSeek uses the OpenAI-compatible chat API; embeddings still use OPENAI_* by default.
AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_EMBEDDING_DIMENSIONS="1536"
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# RAG vector search is disabled by default so first-time local setup works without embedding backfill.
# Set both to "true" after OPENAI_API_KEY is configured and knowledge embeddings have been generated.
KNOWLEDGE_SEMANTIC_RERANK="false"
KNOWLEDGE_VECTOR_SEARCH="false"

# Backend
BACKEND_PORT="4000"
JWT_ACCESS_SECRET="replace-with-a-long-random-production-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-production-secret"
JWT_ACCESS_TTL_SECONDS="900"
JWT_REFRESH_TTL_SECONDS="604800"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/google/callback"

# Local development: http://localhost:3000
# Production: set this to the Vercel domain, e.g. https://metamystic.vercel.app
FRONTEND_APP_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"

# Frontend
FRONTEND_PUBLIC_API_BASE_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
