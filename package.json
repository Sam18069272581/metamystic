{
  "name": "metamystic",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @metamystic/backend --filter @metamystic/frontend dev",
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm -r typecheck",
    "lint": "corepack pnpm -r lint",
    "verify:repo-config": "node scripts/verify-repo-config.mjs",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "test": "corepack pnpm -r test"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
